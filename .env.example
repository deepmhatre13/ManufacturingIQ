# ManufacturingIQ Environment Configuration
# Copy this file to .env and fill in your values

# Backend API Authentication
# Comma-separated list of valid API keys for the /predict endpoint
MANUFACTURINGIQ_API_KEYS=changeme-dev-key

# Dashboard-to-Backend Authentication
# API key used by the Streamlit dashboard to authenticate to the backend
MANUFACTURINGIQ_API_KEY=changeme-dev-key

# Backend API URL
# Default: http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# Environment Mode
# Options: development, production
# Controls logging format (human-readable vs JSON)
ENV=development

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Gemini API Key (for AI agent features)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
